---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = (await getCollection('concepts')).sort(
  (a, b) => a.data.order - b.data.order,
);

const rendered = await Promise.all(
  sections.map(async (section) => {
    const { Content } = await render(section);
    return { section, Content };
  }),
);
---

<BaseLayout
  title="About"
  description="Learn about axillism, how Pitstop works, and what this MVP demo is all about."
>
  <article class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-10">
    <header class="mb-8 sm:mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl">Concepts</h1>
      <p class="mt-3 text-brown/80">
        New here? Start with the basics — then browse the
        <a href="/" class="text-charcoal underline decoration-rose/60 underline-offset-2 hover:decoration-rose">feed</a>
        or explore our
        <a href="/creators" class="text-charcoal underline decoration-rose/60 underline-offset-2 hover:decoration-rose">creators</a>.
      </p>
    </header>

    <div class="space-y-12">
      {
        rendered.map(({ section, Content }) => (
          <section id={section.id} class="scroll-mt-24">
            <h2 class="text-2xl sm:text-3xl lg:text-4xl">{section.data.title}</h2>
            <div class="prose prose-sm prose-rose mt-4 max-w-none sm:prose-base prose-headings:font-heading prose-headings:text-charcoal prose-h3:text-xl sm:prose-h3:text-2xl prose-p:text-brown prose-a:text-burgundy prose-a:underline prose-a:decoration-rose/60 hover:prose-a:decoration-rose prose-strong:text-charcoal prose-p:break-words">
              <Content />
            </div>
          </section>
        ))
      }
    </div>
  </article>
</BaseLayout>
