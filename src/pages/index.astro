---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getPostsWithCreators } from '../lib/content';

const posts = getPostsWithCreators();
---

<BaseLayout title="Home">
  <Hero />

  <section id="feed" class="mx-auto max-w-xl scroll-mt-24 px-4 py-6 sm:scroll-mt-20 sm:px-6 sm:py-8">
    <div class="space-y-6">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
