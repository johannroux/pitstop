---
import BaseLayout from '../layouts/BaseLayout.astro';
import CreatorCard from '../components/CreatorCard.astro';
import { getCreators } from '../lib/content';

const creators = getCreators();
---

<BaseLayout
  title="Creators"
  description="Browse fictional armpit content creators on Pitstop — a curated marketplace demo."
>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <header class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl">Creators</h1>
      <p class="mt-3 text-brown/80">
        Meet the talent shaping the pit stop experience. Every profile here is
        fictional — a preview of the marketplace we're building, not a storefront
        (yet).
      </p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {creators.map((creator) => <CreatorCard creator={creator} />)}
    </div>
  </section>
</BaseLayout>
